{
  "name": "jimixer-com",
  "version": "0.1.0",
  "private": true,
  "description": "Personal website and tech stack showcase for jimixer.com",
  "license": "MIT",
  "author": "jimixer",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimixer/jimixer.com"
  },
  "bugs": {
    "url": "https://github.com/jimixer/jimixer.com/issues"
  },
  "homepage": "https://jimixer.com",
  "keywords": [
    "personal-website",
    "nextjs",
    "aws-cdk",
    "cloudfront",
    "static-site"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=website",
    "dev:gallery": "npm run dev --workspace=gallery-manager",
    "build": "npm run build --workspace=website",
    "build:gallery": "npm run build --workspace=gallery-manager",
    "cdk": "npm run cdk --workspace=infrastructure",
    "deploy:infra": "npm run deploy --workspace=infrastructure",
    "deploy:site": "npm run deploy:site --workspace=infrastructure",
    "test:ci": "npm run build --workspace=website && npm run build --workspace=gallery-manager && npm run build --workspace=infrastructure"
  },
  "workspaces": [
    "website",
    "infrastructure",
    "gallery-manager"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "volta": {
    "node": "20.20.0",
    "npm": "10.8.2"
  }
}
