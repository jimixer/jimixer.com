# AWS Configuration
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Or use AWS Profile (recommended)
AWS_PROFILE=jimixer

# S3 Bucket for gallery images
S3_BUCKET=gallery.jimixer.com

# Gallery image URL (for displaying images in manager)
NEXT_PUBLIC_GALLERY_URL=https://gallery.jimixer.com
