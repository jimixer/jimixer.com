# AWS Profile for jimixer.com project
# Copy this file to .envrc and configure with your AWS credentials

# Clear environment variable credentials (use profile instead)
unset AWS_ACCESS_KEY_ID
unset AWS_SECRET_ACCESS_KEY

# AWS Profile (configure via `aws configure --profile jimixer`)
export AWS_PROFILE=jimixer

# AWS Account and Region for CDK
export AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID
export AWS_REGION=ap-northeast-1

# ACM Certificate ARN (must be in us-east-1 for CloudFront)
export CERTIFICATE_ARN=arn:aws:acm:us-east-1:YOUR_ACCOUNT_ID:certificate/YOUR_CERTIFICATE_ID

# Optional: Domain name (defaults to jimixer.com)
# export DOMAIN_NAME=jimixer.com
